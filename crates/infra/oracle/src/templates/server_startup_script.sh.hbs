#!/bin/bash
# Mirror all output to the OCI serial console (visible under Instance → Console
# History in the OCI web console) and to /var/log/byocvpn-setup.log.
exec > >(tee /dev/console /var/log/byocvpn-setup.log) 2>&1
set -xe

# Detect the default network interface (enp0s3 on OCI ARM, ens3 on older shapes).
DEFAULT_IFACE=$(ip route show default | awk '/default/ {print $5; exit}')
echo "[byocvpn] Default interface: $DEFAULT_IFACE"

# Open WireGuard port (UDP) and status server port (TCP) in the OS-level iptables
# firewall before starting the status server. OCI instances have a default-deny
# host firewall that the other providers do not have.
iptables  -I INPUT   -p udp --dport 51820 -j ACCEPT
iptables  -I INPUT   -p tcp --dport 51820 -j ACCEPT
iptables  -I FORWARD -j ACCEPT
iptables  -t nat -A POSTROUTING -o "$DEFAULT_IFACE" -j MASQUERADE
ip6tables -I INPUT   -p udp --dport 51820 -j ACCEPT
ip6tables -I INPUT   -p tcp --dport 51820 -j ACCEPT
ip6tables -I FORWARD -j ACCEPT
ip6tables -t nat -A POSTROUTING -o "$DEFAULT_IFACE" -j MASQUERADE

# Write initial status and start the TCP status server on port 51820.
# Python 3 is available before any package installation, so this covers the
# full script lifetime including package installation failures.
echo '{"status":"pending"}' > /tmp/byocvpn-status
python3 - <<'PYEOF' &
{{{status_server_script}}}
PYEOF

# If the script exits for any reason before reaching the end, write status:error
# so the client receives a definitive failure response instead of status:pending.
trap 'grep -qF "ready" /tmp/byocvpn-status || echo '"'"'{"status":"error"}'"'"' > /tmp/byocvpn-status' EXIT

apt-get update -y
apt-get install -y wireguard iptables

# Write the WireGuard config with the detected interface name substituted.
sed "s/__DEFAULT_IFACE__/$DEFAULT_IFACE/g" >/etc/wireguard/wg0.conf <<'EOF'
{{{wg_config}}}
EOF

echo "[byocvpn] WireGuard config written:"
cat /etc/wireguard/wg0.conf

echo "net.ipv4.ip_forward=1">>/etc/sysctl.conf
echo "net.ipv6.conf.all.forwarding=1">>/etc/sysctl.conf
# Keep accepting Router Advertisements even with forwarding on, so the VM
# retains its OCI SLAAC IPv6 address and default route.
echo "net.ipv6.conf.all.accept_ra=2">>/etc/sysctl.conf
sysctl -p

systemctl start wg-quick@wg0
systemctl enable wg-quick@wg0
echo "[byocvpn] wg-quick status:"
systemctl status wg-quick@wg0 --no-pager || true
echo "[byocvpn] WireGuard interface:"
wg show || true

echo '{"status":"ready"}' > /tmp/byocvpn-status
echo "[byocvpn] Setup complete."
