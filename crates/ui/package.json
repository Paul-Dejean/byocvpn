{
  "name": "ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "cross-env CARGO_TARGET_DIR=../../../target/tauri tauri",
    "tauri:dev": "cargo build -p byocvpn_daemon --manifest-path ../../Cargo.toml && cross-env CARGO_TARGET_DIR=../../../target/tauri tauri dev",
    "tauri:dev:external-daemon": "cross-env CARGO_TARGET_DIR=../../../target/tauri tauri dev -- --features external-daemon",
    "tauri:build": "cross-env CARGO_TARGET_DIR=../../../target/tauri tauri build"
  },
  "dependencies": {
    "@fontsource-variable/outfit": "^5.2.8",
    "@tailwindcss/vite": "^4.1.10",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-store": "^2.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.6.0",
    "tailwindcss": "^4.1.10"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "cross-env": "^7.0.3",
    "typescript": "~5.6.2",
    "vite": "^6.0.3"
  }
}
